# --- LLM -------------------------------------------------------------------
# Provider for the agent's model calls: openrouter (default) | openai | anthropic
LLM_PROVIDER=openrouter

# OpenRouter (default) — OpenAI-compatible API. Get a key at openrouter.ai/keys.
OPENROUTER_API_KEY=sk-or-v1-...
# Any tool-capable model id from openrouter.ai/models. Default is strong and
# handles Arabic well; alternatives: google/gemini-2.5-pro, openai/gpt-4.1.
OPENROUTER_MODEL=anthropic/claude-sonnet-4.6
# Optional: identify your app on OpenRouter's leaderboards.
# OPENROUTER_HTTP_REFERER=https://your-site.example
# OPENROUTER_TITLE=Data Analyst Agent
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# OR direct Anthropic access (set LLM_PROVIDER=anthropic):
# ANTHROPIC_API_KEY=sk-ant-...
# Spec originally named claude-sonnet-4-20250514 (deprecated, retires 2026-06-15).
# claude-sonnet-4-6 is the drop-in replacement; see DECISIONS.md.
# ANTHROPIC_MODEL=claude-sonnet-4-6

# OR an OpenAI-compatible backend such as Ollama (set LLM_PROVIDER=openai).
# OPENAI_API_KEY is ignored by Ollama but must be non-empty. Pick a tool-capable
# model (qwen2.5:7b, llama3.1:8b, mistral-nemo) and `ollama pull` it first.
# LLM_PROVIDER=openai
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_API_KEY=ollama
# OPENAI_MODEL=qwen2.5:7b

# --- Storage -----------------------------------------------------------------
# SQLite for development; docker-compose overrides this with Postgres.
DATABASE_URL=sqlite:///./data_analyst.db
WORKSPACE_ROOT=./workspaces

# Only needed when the API itself runs inside Docker (docker-compose):
# the HOST path that WORKSPACE_ROOT is bind-mounted from, so sibling sandbox
# containers can mount session workspaces.
# SANDBOX_HOST_WORKSPACE_ROOT=/absolute/host/path/workspaces

# --- Sandbox -------------------------------------------------------------------
SANDBOX_IMAGE=data-analyst-sandbox:latest
SANDBOX_TIMEOUT_S=60

# --- Limits ---------------------------------------------------------------------
MAX_FILE_MB=25
MAX_ROWS=500000
MAX_ANALYSIS_STEPS=12

# --- Security / limits ----------------------------------------------------------
# Lock CORS down to your web origin(s) in production (comma-free JSON list), e.g.
# CORS_ORIGINS=["https://app.example.com"]
# Per-IP requests/minute (0 disables). In-memory — front with Redis/gateway when
# running multiple processes for a hard guarantee.
RATE_LIMIT_PER_MINUTE=120
# Cap on simultaneous sandbox containers across the process.
MAX_CONCURRENT_SANDBOXES=4
